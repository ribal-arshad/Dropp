{
  "name": "@droppjs/cli",
  "version": "0.1.0",
  "type": "module",
  "author": "Ribal Arshad",
  "bin": {
    "dropp": "./bin/run.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run manifest",
    "manifest": "oclif manifest .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "clean": "rimraf dist oclif.manifest.json node_modules/@droppjs",
    "prepack": "node ./scripts/prepare-standalone.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.730.0",
    "@azure/storage-blob": "^12.26.0",
    "@google-cloud/storage": "^7.14.0",
    "@droppjs/config": "workspace:*",
    "@droppjs/core": "workspace:*",
    "@droppjs/plugins-core": "workspace:*",
    "@droppjs/storage-azure": "workspace:*",
    "@droppjs/storage-gcs": "workspace:*",
    "@droppjs/storage-local": "workspace:*",
    "@droppjs/storage-r2": "workspace:*",
    "@droppjs/storage-s3": "workspace:*",
    "@droppjs/transformer-image": "workspace:*",
    "@droppjs/transformer-video": "workspace:*",
    "@droppjs/types": "workspace:*",
    "@oclif/core": "^4.0.29",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "js-yaml": "^4.1.0",
    "mime-types": "^3.0.2",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "bundledDependencies": [
    "@droppjs/config",
    "@droppjs/core",
    "@droppjs/plugins-core",
    "@droppjs/storage-azure",
    "@droppjs/storage-gcs",
    "@droppjs/storage-local",
    "@droppjs/storage-r2",
    "@droppjs/storage-s3",
    "@droppjs/transformer-image",
    "@droppjs/transformer-video",
    "@droppjs/types"
  ],
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "oclif": "^4.17.36",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  },
  "oclif": {
    "bin": "dropp",
    "commands": "./dist/commands"
  }
}
