{
  "name": "@droppjs/adapter-nestjs",
  "version": "0.1.0",
  "author": "Ribal Arshad",
  "description": "NestJS adapter for Dropp media management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "express": "^4.18.0"
  },
  "dependencies": {
    "@droppjs/core": "workspace:*",
    "@droppjs/types": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/common": "^10.2.10",
    "@nestjs/core": "^10.2.10",
    "@nestjs/platform-express": "^10.2.10",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.5.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.1.13",
    "typescript": "^5.3.3"
  }
}
